sub getope {
# mode 0 ... opecode
# mode 1 ... mask
    local( $code, $mode ) = @_;
    local( $val, $i );
    local( @strs );
    $val = 0;
    @strs = split( //, $code );
    for( $i = 0 ; $i < 8 ; $i++ ) {
	if( $debug ) {
	    printf( "%s ", $strs[$i] );
	}
	if( "0" eq $mode ) { # opecode
	    if( "1" eq $strs[$i] ) {
		$val  |= (0x80 >> $i);
	    }
	}
	if( "1" eq $mode ) { # mask
	    if( $strs[$i] =~ /[01]/ ) {
		$val |= (0x80 >> $i);
	    }
	}
	if( $mode =~ /[dwWsrcD]/ ) {
	    if( $strs[$i] eq $mode ) {
		$val |= (0x80 >> $i );
	    }
	}
    }
    if( $debug ) {
	printf( "\n" );
    }
    return( $val );
}

