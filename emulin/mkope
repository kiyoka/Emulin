	$ope[0]  = &getope( $buf[1], "0" );
	$mask[0] = &getope( $buf[1], "1" );
	$d[0]    = &getope( $buf[1], "d" );
	$w[0]    = &getope( $buf[1], "w" );
	$W[0]    = &getope( $buf[1], "W" );
	$s[0]    = &getope( $buf[1], "s" );
	$r[0]    = &getope( $buf[1], "r" );
	$c[0]    = &getope( $buf[1], "c" );
	$D[0]    = &getope( $buf[1], "D" );
	$ope[1]  = &getope( $buf[2], "0" );
	$mask[1] = &getope( $buf[2], "1" );
	$d[1]    = &getope( $buf[2], "d" );
	$w[1]    = &getope( $buf[2], "w" );
	$W[1]    = &getope( $buf[2], "W" );
	$s[1]    = &getope( $buf[2], "s" );
	$r[1]    = &getope( $buf[2], "r" );
	$c[1]    = &getope( $buf[2], "c" );
	$D[1]    = &getope( $buf[2], "D" );
	$opebytes = 2;
	if(
	   ($d[1] == 0) &&
	   ($w[1] == 0) &&
	   ($W[1] == 0) &&
	   ($s[1] == 0) &&
	   ($r[1] == 0) &&
	   ($c[1] == 0) &&
	   ($D[1] == 0)
	   ) {
	    $opebytes = 1;
	}
	if( $mask[1] == 0xFF ) {   # $B$?$@$7!"(B 2byte$BL\$N%*%Z%3!<%I$,A4$FM-8z$J$i!"(B2byte$B%*%Z%3!<%I$H$9$k(B
	    $opebytes = 2;
	}

	# $B%G!<%?=PNO(B
	printf( "    _add_inst( %d, Instruction.%s, \"%s\", %d, " . 
	        " (byte)0x%x, (byte)0x%x, (byte)0x%x, (byte)0x%x, (byte)0x%x, (byte)0x%x, (byte)0x%x, " .
                " (byte)0x%x, (byte)0x%x, (byte)0x%x, (byte)0x%x, (byte)0x%x, (byte)0x%x, (byte)0x%x, " .
                " (byte)0x%x, (byte)0x%x, (byte)0x%x, (byte)0x%x, \'%s\' );\n",
	       $inst_id++, $buf[0], $buf[0], $opebytes,
	       $d[0], $w[0], $W[0], $s[0], $r[0], $c[0], $D[0],
	       $d[1], $w[1], $W[1], $s[1], $r[1], $c[1], $D[1],
	       $ope[0], $ope[1], $mask[0], $mask[1], $buf[3]
	       );

	if( $verbose ) {
	    printf( ">:opebytes = %d\n", $opebytes );
	    printf( ">:name     = %s\n", $buf[0] );
	    printf( ">:str  0   = %s\n", $buf[1] );
	    printf( ">:ope  0   = %x\n", $ope[0] );
	    printf( ">:mask 0   = %x\n", $mask[0] );
	    printf( ">:str  1   = %s\n", $buf[2] );
	    printf( ">:ope  1   = %x\n", $ope[1] );
	    printf( ">:mask 1   = %x\n", $mask[1] );
	    printf( ">:d        = %x\n", $d[0] );
	    printf( ">:w        = %x\n", $w[0] );
	    printf( ">:W        = %x\n", $W[0] );
	    printf( ">:s        = %x\n", $s[0] );
	    printf( ">:r        = %x\n", $r[0] );
	    printf( ">:c        = %x\n", $c[0] );
	    printf( ">:D        = %x\n", $D[0] );
	    printf( ">:operand  = %s\n", $buf[3] );
	}
	$mask_list[$n] = $mask[0]; # $mask[0] << 8 | $mask[1];
	$ope_list[$n]  = $ope[0]; # $ope[0]  << 8 |  $ope[1];
	$buf_list[$n]  = $buf[2];
	$n++;
    }

    # $BL?Na%$%s%G%C%/%9$N:n@.(B
    printf( " inst_search_list = new short[256]; \n" );
#    printf( " inst_search_list[] = { \n" );
    $n--; # <- opecode.dat $B$N(B Unknown $BL?Na$NJ,$r%^%$%J%9$9$k(B
    for( $i = 0 ; $i < 256 ; $i++ ) {
	$found = 0;
	for( $id = 0 ; $id < $n ; $id++ ) {
	    $_mask =  $mask_list[$id];
	    $_ope  =  $ope_list[$id];
	    if( ( $buf_list[$id] eq "--------" ) && ( $_ope == ( $i & $_mask ))) {
		$found = 1;
		# printf( "// index=%04X : id=%d  ( ope=%04X,mask=%04X ); \n", $i, $id, $_ope, $_mask );
		printf( "  inst_search_list[0x%04X] = %d;\n", $i, $id );
	    }
	}
	if( ! $found ) {
	    printf( "  inst_search_list[0x%04X] = %d;\n", $i, -1 );
	}
    }
#    printf( "};" );
}

