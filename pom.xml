<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>net.nishiyama</groupId>
  <artifactId>emulin</artifactId>
  <version>0.5.0</version>
  <packaging>jar</packaging>

  <name>Emulin</name>
  <description>Java-based EMUlation technology for Linux IA-32 / x86-64 Native application</description>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <!-- issue #9: AF_UNIX (UnixDomainSocketAddress / StandardProtocolFamily.UNIX)
         を使うため Java 16+ が必要。LTS の 17 を最低 release としていたが…
         issue #221 (HW 仮想化 backend、Hyper-V/KVM/HVF) の Phase 0 で
         **Java FFM (Project Panama / java.lang.foreign)** を採用するため
         Java 22 (FFM finalized) 以上が必須になる。Phase R (#231/#232/#233)
         までの refactor は Java 17 互換を維持していたが、本 PR (issue #221
         Phase 0 prep) で **release を 25 (LTS) に bump** する。

         - Java 25 LTS (2025-09 GA) を採用。non-LTS の 22/23/24 を経由せず、
           長期サポートのある LTS で固定する。
         - FFM API (`java.lang.foreign.Arena` / `Linker` / `MemorySegment`)
           が finalized で利用可能 (Java 22+)。
         - JLine 3.27.1 / ASM 9.6 / Maven 3.13 共に JDK 25 対応済 (確認済)。
         - 配布 zip (jre-bundle / demo-bundle) も JDK 25 ベースに切り替え
           (dist/build-jre-bundle.sh, dist/build-demo-bundle.sh)。 -->
    <maven.compiler.release>25</maven.compiler.release>
    <jline.version>3.27.1</jline.version>
  </properties>

  <dependencies>
    <!-- Phase 22 step 3: raw tty / 行編集 / SIGWINCH を Windows/POSIX 共通で
         扱うために JLine を採用。emu_con.c (JNI) を将来削除する受け皿。 -->
    <dependency>
      <groupId>org.jline</groupId>
      <artifactId>jline-terminal</artifactId>
      <version>${jline.version}</version>
    </dependency>
    <!-- Phase 30: Windows Console API + POSIX termios 経由の raw mode を
         実装する terminal provider。これが無いと DumbTerminal にフォール
         バックして vim/emacs 等の対話 binary でキー入力が cooked mode
         (Enter まで buffer) になり raw mode 動作しない。 -->
    <dependency>
      <groupId>org.jline</groupId>
      <artifactId>jline-terminal-jni</artifactId>
      <version>${jline.version}</version>
    </dependency>
    <!-- Phase 34-A3: x86-64 命令を Java bytecode に翻訳して実行 (interpreter
         を bypass) するための bytecode emitter。ASM 9.6 は ~125KB と軽量、
         JDK 21 まで full サポート。 -->
    <dependency>
      <groupId>org.ow2.asm</groupId>
      <artifactId>asm</artifactId>
      <version>9.6</version>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <compilerArgs>
            <!-- 生コレクション (Vector 等) の unchecked 警告は Phase 2 で対処 -->
            <arg>-Xlint:-unchecked</arg>
            <arg>-Xlint:-deprecation</arg>
          </compilerArgs>
        </configuration>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.4.2</version>
        <configuration>
          <archive>
            <manifest>
              <mainClass>emulin.Emulin</mainClass>
            </manifest>
          </archive>
        </configuration>
      </plugin>

      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.3.0</version>
        <configuration>
          <mainClass>emulin.Emulin</mainClass>
        </configuration>
      </plugin>

      <!-- Phase 22 step 3f: ディストリビューション用の fat jar。
           target/emulin-${version}-all.jar に jline 系をすべて含めて、
           java -jar 一発で起動できるようにする。 -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <shadedArtifactAttached>true</shadedArtifactAttached>
              <shadedClassifierName>all</shadedClassifierName>
              <createDependencyReducedPom>false</createDependencyReducedPom>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                  <mainClass>emulin.Emulin</mainClass>
                </transformer>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
